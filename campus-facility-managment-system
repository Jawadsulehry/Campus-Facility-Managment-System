static inline vector<string> splitLine(const string& line, char delim = '|') {
    vector<string> parts;
    string token;
    stringstream ss(line);
    while (getline(ss, token, delim)) {
        parts.push_back(token);
    }
    return parts;
}

// ============================================================================
// PERSISTENCE - SAVE/LOAD
// ============================================================================

void saveData(const vector<Facility*>& facilities, const vector<Booking*>& bookings, const vector<student*>& users) {
    // Save users
    ofstream uf("users.txt");
    if (uf.is_open()) {
        for (const student* u : users) {
            uf << u->getId() << '|' << u->getName() << '|' << u->getPassword() << '|' << u->getRole() << '|' << u->getBalance() << '\n';
        }
        uf.close();
    }
    else {
        cerr << "Failed to open users.txt for writing\n";
    }

    // Save facilities
    ofstream ff("facilities.txt");
    if (ff.is_open()) {
        for (const Facility* f : facilities) {
            ff << f->getid() << '|' << f->getname() << '|' << f->getrate() << '|' << f->getcapacity() << '|' << (f->isavailable() ? 1 : 0) << '\n';
        }
        ff.close();
    }
    else {
        cerr << "Failed to open facilities.txt for writing\n";
    }

    // Save bookings
    ofstream bf("bookings.txt");
    if (bf.is_open()) {
        for (const Booking* b : bookings) {
            bf << b->getBookingid() << '|' << b->getUserid() << '|' << b->getFacilityid() << '|' << b->getUsername() << '|' << " " << '|' << b->getStarthour() << '|' << b->getduration() << '|' << b->getcost() << '|' << b->getstatus() << '\n';
        }
        bf.close();
    }
    else {
        cerr << "Failed to open bookings.txt for writing\n";
    }
}

void loadData(vector<Facility*>& facilities, vector<Booking*>& bookings, vector<student*>& users) {
    // Clear existing data
    for (Facility* f : facilities) delete f;
    facilities.clear();
    for (Booking* b : bookings) delete b;
    bookings.clear();
    for (student* u : users) delete u;
    users.clear();

    // Load users
    ifstream uf("users.txt");
    if (uf.is_open()) {
        string line;
        while (getline(uf, line)) {
            if (line.empty()) continue;
            vector<string> parts = splitLine(line);
            if (parts.size() >= 5) {
                int id = stoi(parts[0]);
                string name = parts[1];
                string pass = parts[2];
                string role = parts[3];
                double bal = stod(parts[4]);
                if (role == "Student") {
                    student* s = new student(id, name, pass, bal);
                    users.push_back(s);
                }
            }
        }
        uf.close();
    }

    // Load facilities
    ifstream ff("facilities.txt");
    if (ff.is_open()) {
        string line;
        while (getline(ff, line)) {
            if (line.empty()) continue;
            vector<string> parts = splitLine(line);
            if (parts.size() >= 5) {
                int id = stoi(parts[0]);
                string name = parts[1];
                double rate = stod(parts[2]);
                int cap = stoi(parts[3]);
                int avail = stoi(parts[4]);
                Facility* f = new Facility(id, name, rate, cap);
                f->setAvailable(avail == 1);
                facilities.push_back(f);
            }
        }
        ff.close();
    }

    // Load bookings
    ifstream bf("bookings.txt");
    if (bf.is_open()) {
        string line;
        while (getline(bf, line)) {
            if (line.empty()) continue;
            vector<string> parts = splitLine(line);
            if (parts.size() >= 9) {
                int bid = stoi(parts[0]);
                int uid = stoi(parts[1]);
                int fid = stoi(parts[2]);
                string uname = parts[3];
                string fname = parts[4];
                int start = stoi(parts[5]);
                int dur = stoi(parts[6]);
                double cost = stod(parts[7]);
                string status = parts[8];
                Booking* b = new Booking(bid, uid, fid, uname, fname, start, dur, cost);
                b->setStatus(status);
                bookings.push_back(b);
            }
        }
        bf.close();
    }
}

