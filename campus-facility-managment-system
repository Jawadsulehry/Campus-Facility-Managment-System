// ============================================================================

void Admin(vector<Facility*>& facility, vector<Booking*>& booking, admin*& admin, vector<student*>& users) {
    cout << "Login successful as Admin." << endl;
    while (true) {
        admin->showMenu();
        int choice;
        cout << "enter the choice: ";
        cin >> choice;
        if (choice == 1) {
            Register(facility);
        }
        else if (choice == 2) {
            cout << "All Facilities:" << endl;
            view(facility);
        }
        else if (choice == 3) {
            cout << "all Bookings " << endl;
            view(booking);
        }
        else if (choice == 4) {
            cout << "Approving booking... coming soon" << endl;
        }
        else if (choice == 5) {
            cout << "Rejecting booking... coming soon" << endl;
        }
        else if (choice == 7) {
            cout << "Saving data..." << endl;
            saveData(facility, booking, users);
            cout << "Data saved." << endl;
        }
        else if (choice == 8) {
            cout << "Logging out..." << endl;
            break;
        }
        else {
            cout << "Invalid choice. Please try again." << endl;
        }
    }
}

void login(admin* admin, vector<Facility*>& facility, vector<student*>& studentusers, vector<Booking*>& booking) {
    string name;
    string password;
    int id;
    cout << "enter the id: ";
    cin >> id;
    cout << "Enter Name: ";
    cin >> name;
    cout << "Enter Password: ";
    cin >> password;
    if (name == admin->getName() && password == admin->getPassword()) {
        Admin(facility, booking, admin, studentusers);
    }
    else {
        cout << "invalid credentials!" << endl;
    }
}

void mainmenu() {
    admin adminuser;
    vector<Facility*> facility;
    vector<Booking*> booking;
    vector<student*> users;
    int choice;
    cout << "CAMPUS FACILITY BOOKING SYSTEM" << endl;

    // Load saved data at startup
    loadData(facility, booking, users);

    while (true) {
        cout << "1. Login" << endl;
        cout << "2. Register" << endl;
        cout << "3. Exit" << endl;
        cout << "Enter choice: " << endl;
        cin >> choice;
        if (choice == 1) {
            login(&adminuser, facility, users, booking);
        }
        else if (choice == 2) {
            Register(users);
        }
        else if (choice == 3) {
            cout << "Saving data before exit..." << endl;
            saveData(facility, booking, users);
            cout << "Exiting the system. Goodbye!" << endl;
            break;
        }
    }

    // Cleanup allocated memory
    for (auto f : facility) delete f;
    for (auto b : booking) delete b;
    for (auto u : users) delete u;
}

